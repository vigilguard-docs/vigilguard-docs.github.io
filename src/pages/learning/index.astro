---
import Layout from "../../layouts/Layout.astro";

const frameworks = [
  {
    acronym: "EASM",
    fullname: "External Attack Surface Management",
    tags: [{ label: "VigilGuard", color: "purple" }, { label: "EASM", color: "gray" }],
    desc: "Discover and monitor everything internet-facing before attackers do.",
    slug: "easm",
    art: "easm",
  },
  {
    acronym: "CTEM",
    fullname: "Continuous Threat Exposure Management",
    tags: [{ label: "VigilGuard", color: "purple" }, { label: "Gartner", color: "gray" }],
    desc: "A Gartner framework for continuously scoping, prioritizing, and validating exposures.",
    slug: "ctem",
    art: "ctem",
  },
  {
    acronym: "TPRM",
    fullname: "Third-Party Risk Management",
    tags: [{ label: "VendorGuard", color: "purple" }, { label: "Risk", color: "amber" }],
    desc: "Systematic process for evaluating and monitoring risks introduced by vendors and partners.",
    slug: "tprm",
    art: "tprm",
  },
  {
    acronym: "BAS",
    fullname: "Breach & Attack Simulation",
    tags: [{ label: "Validation", color: "red" }, { label: "CrisisReady", color: "gray" }],
    desc: "Automated, continuous testing of security controls against real attack techniques.",
    slug: "bas",
    art: "bas",
  },
  {
    acronym: "ASM",
    fullname: "Attack Surface Management",
    tags: [{ label: "Surface", color: "amber" }, { label: "VigilGuard", color: "purple" }],
    desc: "Discovery and management of all assets that could be targeted — internal and external.",
    slug: "asm",
    art: "asm",
  },
  {
    acronym: "IAM",
    fullname: "Identity & Access Management",
    tags: [{ label: "Identity", color: "teal" }, { label: "Risk", color: "amber" }],
    desc: "Controls who can access what — the primary attack vector in modern breaches.",
    slug: "iam",
    art: "iam",
  },
  {
    acronym: "IRM",
    fullname: "Integrated Risk Management",
    tags: [{ label: "Risk", color: "amber" }, { label: "Governance", color: "green" }],
    desc: "Unified framework for identifying, assessing, and prioritizing risk across the enterprise.",
    slug: "irm",
    art: "irm",
  },
  {
    acronym: "CTI",
    fullname: "Cyber Threat Intelligence",
    tags: [{ label: "Intelligence", color: "teal" }, { label: "CrisisReady", color: "gray" }],
    desc: "Structured collection and analysis of adversary TTPs to inform defensive decisions.",
    slug: "cti",
    art: "cti",
  },
  {
    acronym: "ZTA",
    fullname: "Zero Trust Architecture",
    tags: [{ label: "Architecture", color: "amber" }, { label: "IAM", color: "teal" }],
    desc: "Never trust, always verify — eliminating implicit trust from every network interaction.",
    slug: "zta",
    art: "zta",
  },
  {
    acronym: "GRC",
    fullname: "Governance, Risk & Compliance",
    tags: [{ label: "Governance", color: "green" }, { label: "Risk", color: "amber" }],
    desc: "Integrated approach aligning IT strategy with business goals, risk tolerance, and regulation.",
    slug: "grc",
    art: "grc",
  },
  {
    acronym: "SOC",
    fullname: "Security Operations Center",
    tags: [{ label: "Operations", color: "red" }, { label: "CrisisReady", color: "gray" }],
    desc: "The team and toolset responsible for monitoring, detecting, and responding to threats in real time.",
    slug: "soc",
    art: "soc",
  },
];
---

<Layout title="Learning Center" isWide={true}>
  <div class="eyebrow">
    <span class="dot"></span>
    Learning Center
  </div>

  <section class="learning-hero">
    <h1>Security Frameworks, Explained</h1>
    <p>No vendor fluff. Practical definitions for the concepts that actually matter.</p>
  </section>

  <div class="learning-grid">
    {frameworks.map((f) => (
      <a href={`/learning/${f.slug}`} class="fw-card">
        <div class="fw-card-inner">
          <div class={`art art-${f.art}`}>
            <span class="art-acronym">{f.acronym}</span>
          </div>
          <div class="fw-body">
            <div class="tag-row">
              {f.tags.map((t) => (
                <span class={`tag tag-${t.color}`}>{t.label}</span>
              ))}
            </div>
            <div class="fw-fullname">{f.fullname}</div>
            <p class="fw-desc">{f.desc}</p>
            <span class="read-more">Read more →</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brand-purple);
    border: 1px solid rgba(115, 103, 240, 0.3);
    padding: 6px 14px;
    border-radius: 100px;
    background: rgba(115, 103, 240, 0.06);
    width: fit-content;
    margin-top: 20px;
    margin-bottom: -80px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-purple);
    box-shadow: 0 0 8px var(--brand-purple);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .learning-hero {
    font-family: "Space Grotesk", sans-serif;
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 20px 20px;
    text-align: center;
  }

  .learning-hero h1 {
    font-size: 36px;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .learning-hero p {
    opacity: 0.7;
    font-size: 16px;
  }

  .learning-grid {
    font-family: "Space Grotesk", sans-serif;
    max-width: 1400px;
    margin: 20px auto 80px;
    padding: 0 20px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .fw-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 14px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(115, 103, 240, 0.2), rgba(0, 0, 0, 0));
    transition: background 0.2s ease;
  }

  .fw-card:hover {
    background: linear-gradient(135deg, rgba(115, 103, 240, 0.45), rgba(0, 0, 0, 0));
  }

  .fw-card-inner {
    border-radius: 13px;
    background: var(--bg-secondary);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* ── ART AREA ── */
  .art {
    position: relative;
    width: 100%;
    height: 140px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .art-acronym {
    position: absolute;
    font-family: "Montserrat", sans-serif;
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -1px;
    z-index: 2;
    color: var(--text-muted);
    pointer-events: none;
    user-select: none;
  }

  /* EASM — radar rings */
  .art-easm { background: transparent; }
  .art-easm::before {
    content: '';
    position: absolute;
    width: 160px; height: 160px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    box-shadow:
      0 0 0 1px rgba(115,103,240,0.5),
      0 0 0 28px rgba(115,103,240,0.1),
      0 0 0 56px rgba(115,103,240,0.05),
      0 0 0 84px rgba(115,103,240,0.02);
    z-index: 1;
  }
  .art-easm::after {
    content: '';
    position: absolute;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #7367f0;
    box-shadow: 0 0 10px 3px rgba(115,103,240,0.5);
    top: calc(50% - 3px); left: calc(50% - 3px);
    z-index: 1;
  }

  /* CTEM */
  .art-ctem { background: transparent; }
  .art-ctem::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 25% 60%, rgba(115,103,240,0.15) 0%, transparent 50%),
      radial-gradient(circle at 75% 35%, rgba(206,159,252,0.1) 0%, transparent 50%);
    z-index: 0;
  }
  .art-ctem::after {
    content: '';
    position: absolute;
    width: 100%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(115,103,240,0.25), transparent);
    top: 50%; z-index: 0;
  }

  /* TPRM */
  .art-tprm { background: transparent; }
  .art-tprm::before {
    content: '';
    position: absolute;
    width: 52px; height: 52px;
    border-radius: 50%;
    border: 1px solid rgba(115,103,240,0.35);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 18px rgba(115,103,240,0.05), 0 0 20px rgba(115,103,240,0.15);
    z-index: 0;
  }
  .art-tprm::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 25%, rgba(224,82,82,0.15) 0%, transparent 28%),
      radial-gradient(circle at 80% 20%, rgba(46,201,122,0.12) 0%, transparent 28%),
      radial-gradient(circle at 15% 75%, rgba(230,168,23,0.12) 0%, transparent 28%),
      radial-gradient(circle at 80% 75%, rgba(29,184,184,0.12) 0%, transparent 28%);
    z-index: 0;
  }

  /* BAS */
  .art-bas { background: transparent; }
  .art-bas::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      90deg, transparent, transparent 18px,
      rgba(224,82,82,0.04) 18px, rgba(224,82,82,0.04) 19px
    );
    z-index: 0;
  }
  .art-bas::after {
    content: '';
    position: absolute;
    width: 100%; height: 1px;
    background: linear-gradient(90deg,
      transparent 0%, rgba(224,82,82,0.5) 40%,
      rgba(224,82,82,0.8) 50%, rgba(224,82,82,0.5) 60%, transparent 100%
    );
    top: 50%; z-index: 0;
  }

  /* ASM */
  .art-asm { background: transparent; }
  .art-asm::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg, transparent, transparent 12px,
      rgba(206,159,252,0.04) 12px, rgba(206,159,252,0.04) 13px
    );
    z-index: 0;
  }
  .art-asm::after {
    content: '';
    position: absolute;
    width: 72px; height: 72px;
    border: 1px solid rgba(224,82,82,0.4);
    border-radius: 4px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%) rotate(15deg);
    z-index: 0;
  }

  /* IAM */
  .art-iam { background: transparent; }
  .art-iam::before {
    content: '';
    position: absolute;
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(29,184,184,0.45);
    top: calc(50% - 28px); left: calc(50% - 19px);
    z-index: 0;
  }
  .art-iam::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 50% 40%, rgba(29,184,184,0.12) 0%, transparent 50%),
      radial-gradient(circle at 20% 80%, rgba(115,103,240,0.08) 0%, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(115,103,240,0.08) 0%, transparent 40%);
    z-index: 0;
  }

  /* IRM */
  .art-irm { background: transparent; }
  .art-irm::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to top, rgba(46,201,122,0.12) 0%, transparent 40%),
      linear-gradient(90deg,
        rgba(46,201,122,0.07) 0%, rgba(46,201,122,0.07) 14%, transparent 14%, transparent 28%,
        rgba(230,168,23,0.08) 28%, rgba(230,168,23,0.08) 42%, transparent 42%, transparent 56%,
        rgba(230,168,23,0.09) 56%, rgba(230,168,23,0.09) 70%, transparent 70%, transparent 84%,
        rgba(224,82,82,0.1) 84%, rgba(224,82,82,0.1) 100%
      );
    z-index: 0;
  }
  .art-irm::after {
    content: '';
    position: absolute;
    width: 100%; height: 1px;
    background: linear-gradient(90deg, rgba(46,201,122,0.3), rgba(230,168,23,0.3), rgba(224,82,82,0.35));
    bottom: 30%; z-index: 0;
  }

  /* CTI */
  .art-cti { background: transparent; }
  .art-cti::before {
    content: '';
    position: absolute;
    width: 68px; height: 68px;
    border-radius: 50%;
    border: 1px solid rgba(29,184,184,0.3);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 16px rgba(29,184,184,0.04);
    z-index: 0;
  }
  .art-cti::after {
    content: '';
    position: absolute;
    width: 68px; height: 20px;
    border-radius: 50%;
    border: 1px solid rgba(29,184,184,0.18);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
  }

  /* ZTA */
  .art-zta { background: transparent; }
  .art-zta::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(90deg, transparent, transparent 28px, rgba(230,168,23,0.1) 28px, rgba(230,168,23,0.1) 29px),
      repeating-linear-gradient(180deg, transparent, transparent 20px, rgba(230,168,23,0.05) 20px, rgba(230,168,23,0.05) 21px);
    z-index: 0;
  }
  .art-zta::after {
    content: '';
    position: absolute;
    width: 1px; height: 60%;
    background: linear-gradient(to bottom, transparent, rgba(230,168,23,0.6), transparent);
    left: 50%; top: 20%;
    z-index: 0;
  }

  /* GRC */
  .art-grc { background: transparent; }
  .art-grc::before {
    content: '';
    position: absolute;
    width: 150px; height: 150px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    box-shadow:
      0 0 0 1px rgba(46,201,122,0.35),
      0 0 0 22px rgba(46,201,122,0.05),
      0 0 0 44px rgba(46,201,122,0.03),
      0 0 0 66px rgba(46,201,122,0.01);
    z-index: 0;
  }
  .art-grc::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(46,201,122,0.08) 0%, transparent 55%);
    z-index: 0;
  }

  /* SOC */
  .art-soc { background: transparent; }
  .art-soc::before {
    content: '';
    position: absolute;
    width: 78px; height: 52px;
    border: 1px solid rgba(224,82,82,0.35);
    border-radius: 4px;
    top: 50%; left: 50%;
    transform: translate(-50%, -52%);
    z-index: 0;
  }
  .art-soc::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 50% 45%, rgba(224,82,82,0.1) 0%, transparent 40%),
      repeating-linear-gradient(180deg, transparent, transparent 6px, rgba(224,82,82,0.03) 6px, rgba(224,82,82,0.03) 7px);
    z-index: 0;
  }

  /* ── BODY ── */
  .fw-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 100px;
    border: 1px solid transparent;
  }

  .tag-purple { color: #7367f0; border-color: rgba(115,103,240,0.3); }
  .tag-green  { color: #2ec97a; border-color: rgba(46,201,122,0.3); }
  .tag-amber  { color: #e6a817; border-color: rgba(230,168,23,0.3); }
  .tag-red    { color: #e05252; border-color: rgba(224,82,82,0.3); }
  .tag-teal   { color: #1db8b8; border-color: rgba(29,184,184,0.3); }
  .tag-gray   { color: var(--text-muted); border-color: var(--border-primary); }

  .fw-fullname {
    font-family: "Montserrat", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .fw-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .read-more {
    font-size: 12px;
    color: var(--accent);
    opacity: 0.7;
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .learning-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .learning-grid {
      grid-template-columns: 1fr;
    }
  }

  .fw-card:hover .read-more {
    opacity: 1;
    text-decoration: underline;
  }
</style>