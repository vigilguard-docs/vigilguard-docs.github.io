---
import Layout from "../../layouts/Layout.astro";
import vigilguardBlog from "../../assets/vigilguard-blog.svg";

const posts = import.meta.glob("./*.md", { eager: true });
const rawFiles = import.meta.glob("./*.md", {
  eager: true,
  query: "?raw",
  import: "default",
});

function truncate(text, max = 265) {
  if (!text || typeof text !== "string") return "";
  const clean = text.replace(/\s+/g, " ").trim();
  if (clean.length <= max) return clean;
  let cut = clean.slice(0, max);
  const lastSpace = cut.lastIndexOf(" ");
  if (lastSpace > max * 0.6) cut = cut.slice(0, lastSpace);
  return cut.trim() + "...";
}

function extractText(path, post) {
  const raw = rawFiles[path];
  const title = post.frontmatter?.title ?? "";
  let body = "";
  if (raw) {
    body = raw
      .replace(/---[\s\S]*?---/, "")
      .replace(/^#{1,6}\s*.+$/gm, "")
      .replace(/^layout:.*$/gm, "")
      .replace(/[#>*_`[\]()-]/g, "")
      .replace(/\n+/g, " ")
      .trim();
  }
  if (title) {
    const escaped = title.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    body = body.replace(new RegExp(escaped, "g"), "");
  }
  return body.replace(/\s+/g, " ").trim();
}

const allPosts = Object.entries(posts)
  .map(([path, post]) => {
    const fullSlug = path.replace("./", "").replace(".md", "");
    const rawText = extractText(path, post);
    return {
      url: `/blog/${fullSlug}`,
      title: post.frontmatter?.title ?? "Untitled",
      date: post.frontmatter?.date ?? "",
      preview: truncate(rawText, 265),
    };
  })
  .sort((a, b) => new Date(b.date) - new Date(a.date));

const pinned = allPosts.find(p => p.url.includes("why-vigilguard"));
const rest = allPosts.filter(p => !p.url.includes("why-vigilguard"));
---

<Layout title="Blog">
      <div class="eyebrow">
      <span class="dot"></span>
      VigilGuard Blog
    </div>

  <section class="blog-hero">
  <img src={vigilguardBlog.src} alt="VigilGuard Blog" width=128" />

    <h1>Blog: Insights on Risk, Security, and Adversarial Thinking</h1>
    <p>Not compliance. Not checklists. Real-world security.</p>
  </section>

  <div class="blog-container">
    <div id="search"></div>

    {pinned && (
      <a href={pinned.url} class="blog-card pinned">
        <div class="blog-card-inner">
          <div class="pinned-header">
            <svg class="pin-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"/>
            </svg>
            <span class="pin-label">Pinned</span>
          </div>
          <p class="blog-date">{pinned.date}</p>
          <h2 class="blog-title">{pinned.title}</h2>
          <p class="blog-preview">{pinned.preview}</p>
          <span class="read-more">Read more →</span>
        </div>
      </a>
    )}

    {rest.map((post) => (
      <a href={post.url} class="blog-card">
        <div class="blog-card-inner">
          <p class="blog-date">{post.date}</p>
          <h2 class="blog-title">{post.title}</h2>
          <p class="blog-preview">{post.preview}</p>
          <span class="read-more">Read more →</span>
        </div>
      </a>
    ))}
  </div>
</Layout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    new PagefindUI({ element: "#search", showImages: false });
  });
</script>

<style>
  .blog-hero {
    font-family: "Space Grotesk", sans-serif;
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px 20px;
    text-align: center;
  }

  .blog-hero h1 {
    font-size: 36px;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .blog-hero p {
    opacity: 0.7;
    font-size: 16px;
  }

  .blog-container {
    font-family: "Space Grotesk", sans-serif;
    max-width: 900px;
    margin: 20px auto 60px;
    padding: 0;
    display: grid;
    gap: 12px;
  }

  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(120, 120, 255, 0.2), rgba(0, 0, 0, 0));
    transition: background 0.2s ease;
  }

  .blog-card:hover {
    background: linear-gradient(135deg, rgba(120, 120, 255, 0.4), rgba(0, 0, 0, 0));
  }

  .blog-card.pinned {
    background: linear-gradient(135deg, rgba(136, 81, 172, 0.35), rgba(0, 0, 0, 0));
  }

  .blog-card-inner {
    background: var(--background);
    padding: 20px;
    border-radius: 12px;
  }
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brand-purple);
    border: 1px solid rgba(115, 103, 240, 0.3);
    padding: 6px 14px;
    border-radius: 100px;
    background: rgba(115, 103, 240, 0.06);
    width: fit-content;
    margin-top: 20px ; margin-bottom: -80px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-purple);
    box-shadow: 0 0 8px var(--brand-purple);
    animation: pulse 2s ease-in-out infinite;
  }
  .pinned-header {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 6px;
  }

  .pin-icon {
    opacity: 0.45;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .pin-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.45;
  }

  .blog-title {
    margin: 6px 0;
    font-size: 22px;
  }

  .blog-date {
    font-size: 12px;
    opacity: 0.5;
  }

  .blog-preview {
    font-size: 14px;
    opacity: 0.75;
    margin: 4px 0 8px;
    line-height: 1.1;
  }

  .read-more {
    font-size: clamp(0.8rem, 0.8vw, 1rem);
    opacity: 0.8;
  }

  .blog-card:hover .read-more {
    opacity: 1;
    text-decoration: underline;
  }
</style>