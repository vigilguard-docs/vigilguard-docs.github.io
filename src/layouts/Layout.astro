---
import Header from "../components/shared/Header.astro";
import Footer from "../components/shared/Footer.astro";
import CookieConsent from "../components/shared/CookieConsent.astro";
import IndexBg from "../components/shared/IndexBg.astro";
import "../styles/style.css";

const { title, frontmatter } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "");
const segments = path.split('/').filter(Boolean);
const isBlogPost = segments.length >= 2 && segments[0] === 'blog';

const displayTitle = frontmatter?.title || title;
const date = frontmatter?.date || "";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{displayTitle} | VigilGuard</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Space+Grotesk:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" />
    <script is:inline>
      const theme = localStorage.getItem("theme") || "light";
      document.documentElement.setAttribute("data-theme", theme);
    </script>
  </head>
  <body>
    <Header />
    <IndexBg />

    <main class="relative z-10">
      {isBlogPost && (
        <div class="circle-back-link">
          <a href="/blog" class="circle-back-btn" aria-label="Back to Blog">←</a>
        </div>
      )}

      <article class="content-container">
        {isBlogPost && (
          <header class="post-research-header">
            <div class="terminal-meta">
              <span>[SYSTEM_INTEL]: {date}</span>
            </div>
            <h1 class="research-title">{displayTitle}</h1>
            <hr class="header-divider" />
          </header>
        )}

        <div class="markdown-body">
          <slot />
        </div>
      </article>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>

<style is:global>
  /* FORCE FONT CHANGE */
  .markdown-body, 
  .markdown-body p, 
  .markdown-body li {
    font-family: "Space Grotesk", sans-serif !important;
    font-size: 18px !important;
    line-height: 1.8 !important;
    color: var(--text-primary) !important;
  }

  .markdown-body h1, 
  .markdown-body h2, 
  .markdown-body h3, 
  .research-title {
    font-family: "Space Grotesk", sans-serif !important;
    font-weight: 700 !important;
  }

  .terminal-meta {
    font-family: "Space Grotesk", monospace !important;
    color: var(--brand-purple);
    font-size: 13px;
    margin-bottom: 10px;
  }

  /* Back Button styling */
  .circle-back-link { position: fixed; bottom: 30px; left: 30px; z-index: 1000; }
  .circle-back-btn { display: flex; align-items: center; justify-content: center; width: 3rem; height: 3rem; background: var(--bg-tertiary); border-radius: 50%; color: var(--text-primary); text-decoration: none; font-size: 1.5rem; border: 1px solid var(--border-translucent); box-shadow: 0 4px 15px var(--shadow-color); }

  @media (max-width: 768px) {
    .circle-back-link { bottom: auto; top: 12px; left: 50%; transform: translateX(-50%); }
    .circle-back-btn { width: 2.5rem; height: 2.5rem; }
  }

  .header-divider { border: 0; height: 1px; background: linear-gradient(to right, var(--brand-purple), transparent); margin: 20px 0; opacity: 0.5; }
</style>