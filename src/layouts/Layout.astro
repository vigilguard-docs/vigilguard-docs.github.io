---
import Header from "../components/shared/Header.astro";
import Footer from "../components/shared/Footer.astro";
import CookieConsent from "../components/shared/CookieConsent.astro";
import IndexBg from "../components/shared/IndexBg.astro";
import vigilguardBlogLogo from "../assets/vigilguard-blog.svg";
import "../styles/style.css";

const { title, frontmatter } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "");
const segments = path.split('/').filter(Boolean);
const isBlogPost = segments.length >= 2 && segments[0] === 'blog';

const displayTitle = frontmatter?.title || title;
const date = frontmatter?.date || "";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{displayTitle} | VigilGuard</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Space+Grotesk:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" />
    <script is:inline>
      const theme = localStorage.getItem("theme") || "light";
      document.documentElement.setAttribute("data-theme", theme);
    </script>
  </head>
  <body>
    <Header />
    <IndexBg />

    {isBlogPost && (
      <div class="circle-back-link">
        <a href="/blog" class="circle-back-btn" aria-label="Back to Blog">←</a>
      </div>
    )}

    <main class="relative z-10">
      <article class="content-container">
        {isBlogPost && (
          <header class="post-research-header">
            <div class="terminal-meta">
              <img src={vigilguardBlogLogo.src} alt="" width="24" height="24" class="blog-logo" />
              <span>[SYSTEM_INTEL]: {date}</span>
            </div>
            <hr class="header-divider" />
          </header>
        )}

        <div class="markdown-body">
          <slot />
        </div>
      </article>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>

<style is:global>
  .markdown-body,
  .markdown-body p,
  .markdown-body li {
    font-family: "Space Grotesk", sans-serif !important;
    font-size: 18px !important;
    line-height: 1.8 !important;
    color: var(--text-primary) !important;
  }

  .markdown-body h1,
  .markdown-body h2,
  .markdown-body h3 {
    font-family: "Space Grotesk", sans-serif !important;
    font-weight: 700 !important;
  }

  .post-research-header {
    padding: 30px 30px 0 30px;
  }

  .terminal-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: "Space Grotesk", monospace !important;
    color: var(--brand-purple);
    font-size: 13px;
    margin-bottom: 10px;
    margin-top: 40px;
  }

  .blog-logo {
    opacity: 0.85;
    flex-shrink: 0;
  }

  .header-divider {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, var(--brand-purple), transparent);
    margin: 20px 0;
    opacity: 0.5;
  }

  /* Back Button */
  .circle-back-link {
    position: fixed;
    bottom: 30px;
    left: 30px;
    z-index: 2000;
  }

  .circle-back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    background: var(--bg-tertiary);
    border-radius: 50%;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 1.5rem;
    border: 1px solid var(--border-translucent);
    box-shadow: 0 4px 15px var(--shadow-color);
    position: relative;
    transition: transform 0.2s ease, background 0.2s ease;
    animation: btn-float 3s ease-in-out infinite;
  }

  .circle-back-btn::before {
    content: "";
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: conic-gradient(
      from var(--angle, 0deg),
      transparent 60%,
      var(--brand-purple) 80%,
      transparent 100%
    );
    animation: shimmer-spin 2.5s linear infinite;
    z-index: -1;
  }

  .circle-back-btn::after {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: 50%;
    background: var(--bg-tertiary);
    z-index: -1;
  }

  .circle-back-btn:hover {
    transform: scale(1.12);
    animation: none;
  }

  .circle-back-btn:active {
    transform: scale(0.93);
  }

  @property --angle {
    syntax: "<angle>";
    inherits: false;
    initial-value: 0deg;
  }

  @keyframes shimmer-spin {
    to { --angle: 360deg; }
  }

  @keyframes btn-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  @media (max-width: 768px) {
    .circle-back-link {
      bottom: auto;
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2000;
    }
    .circle-back-btn {
      width: 2.5rem;
      height: 2.5rem;
    }
  }
</style>