---
// src/layouts/Layout.astro
import Header from "../components/shared/Header.astro";
import Footer from "../components/shared/Footer.astro";
import CookieConsent from "../components/shared/CookieConsent.astro";
import IndexBg from "../components/shared/IndexBg.astro";
import vigilguardBlogLogo from "../assets/vigilguard-blog.svg";
import "../styles/style.css";

const { title, frontmatter, isWide } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "");
const segments = path.split("/").filter(Boolean);
const isBlogPost =
  segments.length >= 2 &&
  (segments[0] === "blog" || segments[0] === "learning");

const displayTitle = frontmatter?.title || title;
const description =
  frontmatter?.description ||
  "VigilGuard documentation and research on system of readiness across attack surface visibility, vendor risk, and crisis response.";

const date = frontmatter?.date || "";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{displayTitle} | VigilGuard Docs</title>

    <link rel="icon" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />

    <meta name="description" content={description} />
    <meta name="author" content="VigilGuard™" />

    <!-- Open Graph -->
    <meta property="og:type" content={isBlogPost ? "article" : "website"} />
    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="https://www.vigilguard.com/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={displayTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://www.vigilguard.com/og-image.png" />

    <!-- Article schema -->
    {
      isBlogPost && (
        <script type="application/ld+json">
          {JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Article",
            headline: displayTitle,
            datePublished: date,
            author: {
              "@type": "Organization",
              name: "VigilGuard"
            }
          })}
        </script>
      )
    }

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Space+Grotesk:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap"
    />

    <script is:inline>
      const theme = localStorage.getItem("theme") || "light";
      document.documentElement.setAttribute("data-theme", theme);
    </script>
  </head>

  <body>
    <Header />
    <IndexBg />

    {
      isBlogPost && (
        <div class="circle-back-link">
          <a
            href={segments[0] === "learning" ? "/learning" : "/blog"}
            class="circle-back-btn"
            aria-label="Back"
          >
            ←
          </a>
        </div>
      )
    }

    <main class="relative z-10">
      <article
        class={isWide
          ? "wide-container"
          : segments[0] === "learning"
            ? "learning-container"
            : "content-container"}
      >
        {
          isBlogPost && (
            <header class="post-research-header">
              <div class="terminal-meta">
                <img
                  src={vigilguardBlogLogo.src}
                  alt=""
                  width="24"
                  height="24"
                  class="blog-logo"
                />
                <span>[SYSTEM_INTEL]: {date}</span>
              </div>
              <hr class="header-divider" />
            </header>
          )
        }

        <div class="markdown-body">
          <slot />
        </div>
      </article>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>

<style is:global>
  .wide-container {
    width: 90vw;
    max-width: 100%;
    padding: 0;
    background-color: var(--bg-primary);
    margin: 0 auto;
  }

  .markdown-body,
  .markdown-body p,
  .markdown-body li {
    font-family: "Space Grotesk", sans-serif !important;
    font-size: 18px !important;
    line-height: 1.8 !important;
    color: var(--text-primary) !important;
  }

  .markdown-body h1,
  .markdown-body h2,
  .markdown-body h3 {
    font-family: "Space Grotesk", sans-serif !important;
    font-weight: 700 !important;
  }

  .post-research-header {
    padding: 30px 30px 0 30px;
  }

  .terminal-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--brand-purple);
    font-size: 13px;
    margin-bottom: 10px;
    margin-top: 40px;
  }

  .header-divider {
    height: 1px;
    background: linear-gradient(to right, var(--brand-purple), transparent);
    margin: 20px 0;
    opacity: 0.5;
  }

  .learning-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 60px 20px;
    background-color: var(--bg-primary);
  }
</style>