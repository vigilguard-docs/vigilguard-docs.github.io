---
import Layout from "../../layouts/Layout.astro";

const posts = import.meta.glob("./*.md", { eager: true });
const rawFiles = import.meta.glob("./*.md", {
  eager: true,
  query: "?raw",
  import: "default",
});

function truncate(text, max = 160) {
  if (!text || typeof text !== "string") return "";
  const clean = text.replace(/\s+/g, " ").trim();
  if (clean.length <= max) return clean;
  let cut = clean.slice(0, max);
  const lastSpace = cut.lastIndexOf(" ");
  if (lastSpace > max * 0.6) cut = cut.slice(0, lastSpace);
  return cut.trim() + "...";
}

function extractText(path, post) {
  const description = post.frontmatter?.description ?? "";
  const raw = rawFiles[path];
  let body = "";
  if (raw) {
    body = raw
      .replace(/---[\s\S]*?---/, "")
      .replace(/^#{1,6}.+$/gm, "")
      .replace(/[#>*_`[\]()-]/g, "")
      .replace(/\n+/g, " ")
      .trim();
  }
  if (description && body) return `${description} — ${body}`;
  if (description) return description;
  return body.replace(/\s+/g, " ").trim();
}

const allPosts = Object.entries(posts)
  .map(([path, post]) => {
    const fullSlug = path.replace("./", "").replace(".md", "");
    const rawText = extractText(path, post);
    return {
      url: `/blog/${fullSlug}`,
      title: post.frontmatter?.title ?? "Untitled",
      date: post.frontmatter?.date ?? "",
      preview: truncate(rawText, 265),
    };
  })
  .sort((a, b) => new Date(b.date) - new Date(a.date));
---

<Layout title="Blog">
  <section class="blog-hero">
    <h1>Insights on Risk, Security, and Adversarial Thinking</h1>
    <p>Not compliance. Not checklists. Real-world security.</p>
  </section>

  <div class="blog-container">
    <div id="search"></div>

    {
      allPosts.map((post) => (
        <a href={post.url} class="blog-card">
          <div class="blog-card-inner">
            <p class="blog-date">{post.date}</p>
            <h2 class="blog-title">{post.title}</h2>
            <p class="blog-preview">{post.preview}</p>
            <span class="read-more">Read more →</span>
          </div>
        </a>
      ))
    }
  </div>
</Layout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    new PagefindUI({ element: "#search", showImages: false });
  });
</script>

<style>
  .blog-hero {
    font-family: "Space Grotesk", sans-serif;
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px 20px;
    text-align: center;
  }

  .blog-hero h1 {
    font-size: 36px;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .blog-hero p {
    opacity: 0.7;
    font-size: 16px;
  }

  .blog-container {
    font-family: "Space Grotesk", sans-serif;
    max-width: 900px;
    margin: 20px auto 60px;
    padding: 0 0px;
    display: grid;
    gap: 12px;
  }

  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(120, 120, 255, 0.2),
      rgba(0, 0, 0, 0)
    );
    transition: background 0.2s ease;
    line-height: -50%;
  }

  .blog-card:hover {
    background: linear-gradient(
      135deg,
      rgba(120, 120, 255, 0.4),
      rgba(0, 0, 0, 0)
    );
  }

  .blog-card-inner {
    background: var(--background);
    padding: 20px;
    border-radius: 12px;
  }

  .blog-title {
    margin: 6px 0;
    font-size: 22px;
  }

  .blog-date {
    font-size: 12px;
    opacity: 0.5;
  }

  .blog-preview {
    font-size: 14px;
    opacity: 0.75;
    margin: 4px 0 8px;
    line-height: 1.1;
  }

  .read-more {
    font-size: clamp(0.8rem, 0.8vw, 1rem);
    opacity: 0.8;
  }

  .blog-card:hover .read-more {
    opacity: 1;
    text-decoration: underline;
  }
</style>